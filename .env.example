# ============================================================
# Velura Fashion Shop — Cấu hình biến môi trường (DEMO / PRODUCTION)
# ============================================================
# Hướng dẫn: Sao chép file này thành .env để chạy dự án.
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
# ============================================================

# --- Cấu hình chung ---
NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174,http://localhost:5175,http://127.0.0.1:5175,http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:3002,http://127.0.0.1:3002,http://localhost:3003,http://127.0.0.1:3003

# --- Supabase (Database + Auth) ---
NEXT_PUBLIC_SUPABASE_URL=https://drvkrpoojyncodfytftn.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_6ELMfwBsM3SFAXQz8-jmOQ_kv1kkGh7

VELURA_SUPABASE_URL=https://drvkrpoojyncodfytftn.supabase.co
VELURA_SUPABASE_ANON_KEY=sb_publishable_6ELMfwBsM3SFAXQz8-jmOQ_kv1kkGh7
VELURA_SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# --- API Server Limits ---
API_REQUEST_TIMEOUT_MS=15000
API_MAX_BODY_BYTES=15728640
ADMIN_MUTATION_LIMIT_PER_MINUTE=60

# --- Chatbot AI (n8n Webhook) ---
N8N_CHAT_WEBHOOK_URL=https://gianth.app.n8n.cloud/webhook/ai-ecommerce-customer-support
N8N_CHAT_WEBHOOK_TOKEN=

# --- Gemini AI (Tính năng tư vấn / gợi ý phong cách) ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-3.5-flash

# --- Mistral AI ---
MISTRAL_API_KEY=your_mistral_api_key_here
MISTRAL_MODEL=mistral-small-latest

# --- SMTP Email (Gmail App Password - Gửi thông báo hỗ trợ) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_gmail_username_here@gmail.com
SMTP_APP_PASSWORD=your_gmail_app_password_here
SMTP_FROM="Velura CSKH <your_gmail_username_here@gmail.com>"
SUPPORT_ALERT_TO=your_gmail_username_here@gmail.com

# --- Bảo vệ Seed Data ---
VELURA_ALLOW_SEED=0
VELURA_SEED_PASSWORD=

# --- Alias Supabase tương thích ngược ---
SUPABASE_URL=https://drvkrpoojyncodfytftn.supabase.co
SUPABASE_ANON_KEY=sb_publishable_6ELMfwBsM3SFAXQz8-jmOQ_kv1kkGh7
SUPABASE_PUBLISHABLE_KEY=sb_publishable_6ELMfwBsM3SFAXQz8-jmOQ_kv1kkGh7
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
VITE_SUPABASE_URL=https://drvkrpoojyncodfytftn.supabase.co
SUPABASE_DB_URL=postgresql://postgres:[password]@db.drvkrpoojyncodfytftn.supabase.co:5432/postgres
SUPABASE_DIRECT_URL=

# --- Cấu hình Worker & Intervals ---
ACCOUNT_MAINTENANCE_INTERVAL_MS=3600000
EMAIL_WORKER_INTERVAL_MS=60000
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=

# --- Gợi ý phong cách AI (Gemini Recommendation Engine) ---
GEMINI_STYLIST_MODEL=gemini-3.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536
RECOMMENDATION_MATCH_THRESHOLD=0.45
RECOMMENDATION_MATCH_COUNT=20

# --- Tùy chọn khác ---
OPENAI_API_KEY=
OPENAI_MODEL=
SMOKE_API_PORT=8799
VELURA_ADMIN_ACCESS_TOKEN=
VELURA_SUPABASE_ACCESS_TOKEN=
