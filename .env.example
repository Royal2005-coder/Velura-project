# ============================================================
# Velura Fashion Shop — Cấu hình biến môi trường
# ============================================================
# Hướng dẫn: Copy file này thành .env rồi điền giá trị thực.
#   Windows:  copy .env.example .env
#   Mac/Linux: cp .env.example .env
#
# ⚠️ KHÔNG BAO GIỜ commit file .env lên Git!
# ============================================================

# --- Cấu hình chung ---
NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173,http://localhost:3001,http://127.0.0.1:5173

# --- Supabase (Database + Auth) ---
# Lấy từ Supabase Dashboard > Project Settings > API
VELURA_SUPABASE_URL=https://your-project.supabase.co
VELURA_SUPABASE_ANON_KEY=your_anon_key_here
VELURA_SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- API Server ---
API_REQUEST_TIMEOUT_MS=15000
API_MAX_BODY_BYTES=65536
ADMIN_MUTATION_LIMIT_PER_MINUTE=60
ACCOUNT_MAINTENANCE_INTERVAL_MS=3600000
EMAIL_WORKER_INTERVAL_MS=60000

# --- Email Webhook (tùy chọn) ---
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=

# --- Chatbot AI (tùy chọn — nếu muốn dùng chatbot) ---
# Webhook tích hợp n8n chatbot workflow
N8N_CHAT_WEBHOOK_URL=
N8N_CHAT_WEBHOOK_TOKEN=

# --- Gemini AI (tùy chọn — cho tính năng gợi ý sản phẩm AI) ---
# Lấy API key từ https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536
GEMINI_STYLIST_MODEL=gemini-3.5-flash
RECOMMENDATION_MATCH_THRESHOLD=0.45
RECOMMENDATION_MATCH_COUNT=20

# --- SMTP Email (tùy chọn — gửi email hỗ trợ khách hàng) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=
SUPPORT_ALERT_TO=

# --- Database trực tiếp (chỉ dùng cho migration script) ---
SUPABASE_DB_URL=postgresql://postgres:[password]@db.your-project.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=

# --- Bảo vệ Seed Data (chỉ dùng khi dev/staging) ---
VELURA_ALLOW_SEED=0
VELURA_SEED_PASSWORD=
VELURA_ALLOW_UNSAFE_HOTFIX=0
