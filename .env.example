# Velura runtime configuration.
# Copy this file to .env locally. Never commit service-role keys or database passwords.

NODE_ENV=development
PORT=8787
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

VELURA_SUPABASE_URL=https://drvkrpoojyncodfytftn.supabase.co
VELURA_SUPABASE_ANON_KEY=sb_publishable_6ELMfwBsM3SFAXQz8-jmOQ_kv1kkGh7
VELURA_SUPABASE_SERVICE_ROLE_KEY=
API_REQUEST_TIMEOUT_MS=15000
API_MAX_BODY_BYTES=65536
ADMIN_MUTATION_LIMIT_PER_MINUTE=60
ACCOUNT_MAINTENANCE_INTERVAL_MS=3600000
EMAIL_WORKER_INTERVAL_MS=60000
EMAIL_WEBHOOK_URL=
EMAIL_WEBHOOK_TOKEN=

# Optional chatbot workflow integration. Keep tokens in deploy secrets.
N8N_CHAT_WEBHOOK_URL=
N8N_CHAT_WEBHOOK_TOKEN=

# Optional Gemini AI recommendation engine. Keep the real key in local/deploy secrets.
GEMINI_API_KEY=
GEMINI_EMBEDDING_MODEL=gemini-embedding-2
GEMINI_EMBEDDING_DIMENSIONS=1536
GEMINI_STYLIST_MODEL=gemini-3.5-flash
RECOMMENDATION_MATCH_THRESHOLD=0.45
RECOMMENDATION_MATCH_COUNT=20

# Optional direct SMTP delivery for queued support emails.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_APP_PASSWORD=
SMTP_FROM=
SUPPORT_ALERT_TO=

# Staging/dev seed protection. Never enable this in production.
VELURA_ALLOW_SEED=0
VELURA_SEED_PASSWORD=

# Optional, for direct migration tools only.
SUPABASE_DB_URL=postgresql://postgres:UelVelura@123@db.drvkrpoojyncodfytftn.supabase.co:5432/postgres
SUPABASE_ACCESS_TOKEN=
SUPABASE_DB_PASSWORD=
VELURA_ALLOW_UNSAFE_HOTFIX=0
